# =============================================================================
# Monitoring - 중앙 설정 파일 (single source of truth)
#
# 사용법:  cp .env.example .env  후 값만 채우면 됩니다.
#   - 모든 값은 공란으로 두고 나중에 채워도 서버는 기동됩니다.
#   - 채워지지 않은 통합은 비활성(no-op)되고, 시작 로그에 누락 키로 보고됩니다.
#   - 실제 OS 환경변수가 이 파일 값을 덮어씁니다(컨테이너/k8s Secret 주입용).
#   - 다른 경로의 파일을 쓰려면 CONFIG_FILE=/path/to/file 로 지정.
# 모든 외부 연동은 {BaseURL, Token} 패턴으로 통일되어 있습니다.
# =============================================================================

# --- HTTP 서버 ---
LISTEN_ADDR=:8080

# --- Slack (봇 토큰 + 서명 시크릿 + 알람 채널) ---
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_ALERT_CHANNEL=
# 기본값 https://slack.com/api - 보통 비워둠
SLACK_BASE_URL=

# --- Grafana (중앙 1개 인스턴스, 멀티클러스터는 라벨로 구분) ---
# 알람 webhook 수신 엔진이자 Silences API 대상.
GRAFANA_BASE_URL=
GRAFANA_API_TOKEN=
# 패널 스크린샷(webhook imageURL)을 Slack 스레드에 인라인 첨부할지.
# true면 Grafana image-renderer 플러그인이 켜져 있어야 imageURL이 채워집니다.
# false(기본)면 패널 링크만 첨부(어느 환경에서나 동작).
GRAFANA_IMAGE_ENABLED=false

# --- Kubernetes (중앙 API 접근; pod image/시작시각 조회) ---
# 중앙 집중형: 단일 API 엔드포인트가 멀티클러스터를 cluster 라벨로 구분.
KUBE_API_URL=
KUBE_TOKEN=
# 자체서명 CA인 in-cluster API면 true (주의해서 사용)
KUBE_INSECURE_SKIP_VERIFY=false

# --- GitHub (배포 revision의 커미터 조회) ---
# 기본값 https://api.github.com - GHE면 https://<host>/api/v3
GITHUB_BASE_URL=
GITHUB_TOKEN=

# --- ArgoCD (app->repo/synced revision 메타데이터 + 롤백) ---
ARGOCD_BASE_URL=
ARGOCD_TOKEN=
# Slack rollback 버튼 on/off (기본 비활성)
ARGOCD_ROLLBACK_ENABLED=false

# --- 로그 원천 링크 (kibana | prometheus) ---
LOG_SOURCE=kibana
KIBANA_BASE_URL=
PROMETHEUS_BASE_URL=
