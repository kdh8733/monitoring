# --- HTTP ---
LISTEN_ADDR=:8080

# --- Central Grafana (single instance, multi-cluster via labels) ---
GRAFANA_BASE_URL=https://grafana.example.com
GRAFANA_API_TOKEN=

# --- Kubernetes (central; multi-cluster via `cluster` label on alerts) ---
# In-cluster: leave KUBECONFIG empty. Out-of-cluster: point to a kubeconfig.
KUBECONFIG=

# --- GitHub ---
GITHUB_TOKEN=

# --- ArgoCD ---
ARGOCD_SERVER=https://argocd.example.com
ARGOCD_TOKEN=
# Feature flag: when false, the Slack rollback button is not rendered/handled.
ARGOCD_ROLLBACK_ENABLED=false

# --- Slack ---
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_ALERT_CHANNEL=

# --- Log source for thread links (kibana | prometheus) ---
LOG_SOURCE=kibana
KIBANA_BASE_URL=https://kibana.example.com
